<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.urms.dao.SysUserDao">

    <resultMap id="BaseResultMap" type="com.urms.entity.SysUser">
        <id column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="role" property="role"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="UserWithStaffResultMap" type="com.urms.entity.SysUser" extends="BaseResultMap">
        <association property="staffInfo" javaType="com.urms.entity.RetiredStaff">
            <id column="staff_id" property="staffId"/>
            <result column="real_name" property="realName"/>
            <result column="photo" property="photo"/>
            <result column="gender" property="gender"/>
            <result column="id_card" property="idCard"/>
            <result column="age" property="age"/>
            <result column="nation" property="nation"/>
            <result column="education" property="education"/>
            <result column="native_place" property="nativePlace"/>
            <result column="work_start_date" property="workStartDate"/>
            <result column="retire_date" property="retireDate"/>
            <result column="former_dept" property="formerDept"/>
            <result column="job_title" property="jobTitle"/>
        </association>
    </resultMap>

    <select id="findByUsername" parameterType="string" resultMap="UserWithStaffResultMap">
        SELECT u.*, s.*
        FROM sys_user u
        LEFT JOIN retired_staff s ON u.user_id = s.staff_id
        WHERE u.username = #{username}
    </select>

    <select id="findById" parameterType="int" resultMap="UserWithStaffResultMap">
        SELECT u.*, s.*
        FROM sys_user u
        LEFT JOIN retired_staff s ON u.user_id = s.staff_id
        WHERE u.user_id = #{userId}
    </select>

    <insert id="insert" parameterType="com.urms.entity.SysUser" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO sys_user (username, password, role, create_time)
        VALUES (#{username}, #{password}, #{role}, NOW())
    </insert>

    <update id="updatePassword" parameterType="map">
        UPDATE sys_user SET password = #{password} WHERE user_id = #{userId}
    </update>

</mapper>